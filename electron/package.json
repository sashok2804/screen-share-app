{
  "name": "@screenshare/electron",
  "version": "0.1.0",
  "private": true,
  "author": "sashok2804",
  "description": "Electron desktop client for the screen-share-app (Windows). Loads the React client over HTTPS and adds per-process WASAPI loopback audio capture (Discord-style, no echo).",
  "type": "commonjs",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win nsis",
    "clean": "rimraf dist out"
  },
  "dependencies": {
    "loopback-capture": "^2.0.0"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "^26.0.0",
    "rimraf": "^5.0.0"
  },
  "build": {
    "appId": "com.sashok2804.screenshare",
    "productName": "Screen Share",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!**/*.map",
      "!dist/**",
      "!out/**",
      "!bin/**",
      "!scripts/**"
    ],
    "extraResources": [],
    "asarUnpack": [
      "**/node_modules/loopback-capture/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Screen Share",
      "differentialPackage": false
    },
    "protocols": [
      {
        "name": "Screen Share URL",
        "schemes": [
          "screen-share"
        ],
        "role": "Viewer"
      }
    ]
  }
}
